# @primer/react@36 declares a peer dep on react@^18, but we use react@19.
# Primer v36 actually runs fine against React 19 in practice — we're stuck
# on v36 because v37 broke our form inputs (CSS Modules regression). Let
# npm install the tree despite the mismatch.
#
# Same setting via CLI: `npm install --legacy-peer-deps`. Keeping it
# here so every contributor (Mac, Windows, CI) gets the same behavior
# without having to remember the flag.
legacy-peer-deps=true
