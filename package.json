{
  "name": "fino",
  "description": "Fino — v2 of Make It Rain (React + Primer + Electron)",
  "version": "2.0.0-alpha.4",
  "private": true,
  "main": "dist-electron/main.js",
  "license": "MIT",
  "author": "Jim Laurie",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron/tsconfig.json",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@primer/octicons-react": "^19.13.0",
    "@primer/react": "^36.27.0",
    "@tanstack/react-query": "^5.59.0",
    "electron-updater": "^6.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.27.0",
    "styled-components": "^5.3.11"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.59.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.makeitrain.fino",
    "productName": "Fino",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "lauriejim",
        "repo": "fino-front",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.finance",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "build/icon.ico"
    }
  }
}
